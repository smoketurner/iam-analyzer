{
    "Version": "2012-10-17",
    "Statement": [
        {
            "Sid": "AllowCrossAccountAssume",
            "Effect": "Allow",
            "Principal": {
                "AWS": [
                    "arn:aws:iam::111111111111:root",
                    "arn:aws:iam::222222222222:root"
                ]
            },
            "Action": "sts:AssumeRole"
        }
    ]
}
