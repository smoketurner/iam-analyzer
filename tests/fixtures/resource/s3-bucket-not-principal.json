{
    "Statement": [
        {
            "Sid": "DenyEveryoneExceptAdmin",
            "Effect": "Deny",
            "NotPrincipal": {
                "AWS": "arn:aws:iam::123456789012:user/admin"
            },
            "Action": "s3:*",
            "Resource": [
                "arn:aws:s3:::sensitive-bucket",
                "arn:aws:s3:::sensitive-bucket/*"
            ]
        },
        {
            "Sid": "AllowAll",
            "Effect": "Allow",
            "Principal": "*",
            "Action": "s3:GetObject",
            "Resource": "arn:aws:s3:::sensitive-bucket/*"
        }
    ]
}
