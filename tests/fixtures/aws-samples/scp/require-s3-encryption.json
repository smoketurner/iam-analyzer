        "original_file": "Service-specific-controls/Amazon-S3/Prevent-Amazon-S3-unencrypted-object-uploads.json",
        "modified": false
    },
    "Version": "2012-10-17",
    "Statement": [
        {
            "Effect": "Deny",
            "Action": "s3:PutObject",
            "Resource": "*",
            "Condition": {
                "Null": {
                    "s3:x-amz-server-side-encryption": "true"
                }
            }
        }
    ]
}
