        "original_file": "Protect-cloud-platform-resource/Enforce-30-days-for-KMS-deletion.json",
        "modified": false
    },
    "Version": "2012-10-17",
    "Statement": [
        {
            "Effect": "Deny",
            "Action": "kms:ScheduleKeyDeletion",
            "Resource": "*",
            "Condition": {
                "NumericLessThan": {
                    "kms:ScheduleKeyDeletionPendingWindowInDays": "30"
                }
            }
        }
    ]
}
