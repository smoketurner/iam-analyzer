        "original_file": "Service-specific-controls/S3-Prevent-long-term-presigned-url.json",
        "modified": true,
        "modification_notes": "Set max signature age to 1 hour (3600000ms) for testing"
    },
    "Version": "2012-10-17",
    "Statement": [
        {
            "Effect": "Deny",
            "Principal": "*",
            "Action": "s3:*",
            "Resource": "*",
            "Condition": {
                "NumericGreaterThan": {
                    "s3:signatureAge": "3600000"
                }
            }
        }
    ]
}
