        "original_file": "Restrict-resource-access-patterns/Restrict-access-to-only-HTTPS-connections-to-your-resources.json",
        "modified": true,
        "modification_notes": "Reduced service list for focused testing"
    },
    "Version": "2012-10-17",
    "Statement": [
        {
            "Effect": "Deny",
            "Principal": "*",
            "Action": [
                "s3:*",
                "sqs:*",
                "secretsmanager:*",
                "kms:*"
            ],
            "Resource": "*",
            "Condition": {
                "BoolIfExists": {
                    "aws:SecureTransport": "false"
                }
            }
        }
    ]
}
