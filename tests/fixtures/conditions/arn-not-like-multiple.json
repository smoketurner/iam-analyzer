{
    "Version": "2012-10-17",
    "Statement": [{
        "Sid": "DenyNonOrgPrincipals",
        "Effect": "Deny",
        "Action": "*",
        "Resource": "*",
        "Condition": {
            "ArnNotLike": {
                "aws:PrincipalArn": [
                    "arn:aws:iam::111111111111:*",
                    "arn:aws:iam::222222222222:*"
                ]
            }
        }
    }]
}
