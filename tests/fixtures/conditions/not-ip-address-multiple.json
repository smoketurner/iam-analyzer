{
    "Version": "2012-10-17",
    "Statement": [{
        "Sid": "DenyNonWhitelistedIPs",
        "Effect": "Deny",
        "Action": "*",
        "Resource": "*",
        "Condition": {
            "NotIpAddress": {
                "aws:SourceIp": ["10.0.0.0/8", "192.168.0.0/16", "172.16.0.0/12"]
            }
        }
    }]
}
